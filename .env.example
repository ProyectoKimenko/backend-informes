# Backend de informes y desagregación de agua — variables de entorno.
# Copia a .env (local) o configúralas en el panel de Dokploy (producción).

# --- Supabase ---
SUPABASE_URL=https://TU_PROYECTO.supabase.co
# El backend prefiere SUPABASE_SERVICE_ROLE_KEY (bypassa RLS, escribe
# perfiles/eventos/readings) y cae a SUPABASE_KEY solo si no está. En producción
# DEFINIR la service_role: con RLS activado y los grants de anon revocados, la
# anon key (pública, va en el frontend) ya no puede leer/escribir las tablas.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key
# Fallback / compat (anon). No es credencial de escritura en producción.
SUPABASE_KEY=tu_anon_key

# --- Redis (broker/result backend de Celery) ---
# En el compose, el host es el nombre del servicio "redis".
REDIS_URL=redis://redis:6379/0

# --- CORS ---
# Orígenes del frontend separados por coma (sin barra final). Ej:
#   ALLOWED_ORIGINS=https://app.kimenko.cl,https://kimenko.cl
# Déjalo en * solo para desarrollo local (deshabilita credenciales).
ALLOWED_ORIGINS=*

# --- Otros ---
PYTHONUNBUFFERED=1
PYTHONPATH=/app
