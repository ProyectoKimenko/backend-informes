import pandas as pd
import numpy as np
from sklearn.cluster import KMeans
from sklearn.preprocessing import StandardScaler
from typing import Tuple, Dict, List, Optional
from itertools import combinations
# -----------------------------------------------------------------------------
# 1. HEURÍSTICA DE NOMBRES (La clave para la estabilidad visual)
# -----------------------------------------------------------------------------
def get_device_category(flow_rate: float) -> str:
    """Asigna nombre consistente basado en caudal físico."""
    if flow_rate < 0.5: return "Ruido"
    if flow_rate < 2.0: return "Fuga / Goteo"
    if flow_rate < 5.0: return "Grifo Baño"
    if flow_rate < 10.0: return "Ducha / Grifo Cocina"
    if flow_rate < 18.0: return "Inodoro / Lavadora"
    return "Riego / Consumo Alto"

# -----------------------------------------------------------------------------
# 2. PREPROCESAMIENTO
# -----------------------------------------------------------------------------
def preprocess_signal(df: pd.DataFrame) -> pd.DataFrame:
    df = df.copy()
    if 'timestamp' in df.columns:
        df['timestamp'] = pd.to_datetime(df['timestamp'], utc=True)
        df = df.set_index('timestamp')
    if not isinstance(df.index, pd.DatetimeIndex):
        raise ValueError("El índice del DataFrame debe ser DatetimeIndex")
    df = df.sort_index()

    if 'flow' not in df.columns and 'flow_rate' in df.columns:
        df.rename(columns={'flow_rate': 'flow'}, inplace=True)
    elif 'flow' not in df.columns:
        raise KeyError("El DataFrame debe contener una columna llamada 'flow' o 'flow_rate'")
    
    # Suavizado para eliminar picos falsos del sensor
    df["flow_smooth"] = df["flow"].rolling(window=5, center=True).median().fillna(df["flow"])
    df["delta"] = df["flow_smooth"].diff().fillna(0)
    return df

# -----------------------------------------------------------------------------
# 3. NÚCLEO DEL ALGORITMO (Disaggregator)
# -----------------------------------------------------------------------------

def run_disaggregation(df: pd.DataFrame, profiles: Dict, penalty_lambda: float = 0.5, temporal_lambda: float = 0.3, prior_lambda: float = 0.2) -> Tuple[pd.DataFrame, pd.DataFrame]:
    if not profiles:
        raise ValueError("No trained profiles provided.")

    if 'timestamp' in df.columns:
        df['timestamp'] = pd.to_datetime(df['timestamp'], utc=True)
        df = df.set_index('timestamp')

    df = df.sort_index()

    if not isinstance(df.index, pd.DatetimeIndex):
        raise ValueError("DataFrame index must be DatetimeIndex")

    df_proc = preprocess_signal(df)
    current_flow = df_proc['flow_smooth']

    device_profiles = list(profiles.values())
    
    # Inicializamos el DataFrame de resultados
    # No pre-definimos columnas para permitir que "No Detectado" se cree dinámicamente
    df_result = pd.DataFrame(0.0, index=current_flow.index, columns=[])

    # Precomputar combinaciones de dispositivos
    all_combos = []
    for r in range(1, len(device_profiles) + 1):
        for combo in combinations(device_profiles, r):
            combo_names = [p['name'] for p in combo]
            combo_sum = sum(p['mean_flow'] for p in combo)
            combo_std = np.mean([max(p.get("st_deviation", 0.5), 0.1) for p in combo])
            combo_prob = np.prod([max(p.get("weight", 0.01), 0.01) for p in combo])

            all_combos.append({
                "names": combo_names,
                "sum": combo_sum,
                "std": combo_std,
                "size": len(combo),
                "prob": combo_prob
            })

    prev_combo = None

    for t, flow_t in current_flow.items():
        if flow_t <= 0:
            prev_combo = None
            continue

        best_score = np.inf
        best_combo = None

        for combo in all_combos:
            if combo["sum"] == 0:
                continue

            flow_error = abs(flow_t - combo["sum"])
            normalized_error = flow_error / combo["std"]
            complexity_penalty = penalty_lambda * combo["size"]

            # Penalización temporal por cambio de estado
            temporal_penalty = 0
            if prev_combo is not None:
                change_cost = len(set(combo["names"]).symmetric_difference(set(prev_combo)))
                temporal_penalty = temporal_lambda * change_cost

            # Prior basado en la probabilidad del cluster entrenado
            prior_penalty = prior_lambda * (-np.log(combo["prob"]))

            score = normalized_error + complexity_penalty + temporal_penalty + prior_penalty

            if score < best_score:
                best_score = score
                best_combo = combo

        # Asignación de caudales
        assigned_this_step = 0
        if best_combo is not None:
            for name in best_combo["names"]:
                mean_i = next(p['mean_flow'] for p in device_profiles if p['name'] == name)
                # Distribución proporcional para conservar la masa (litros)
                assigned_value = flow_t * (mean_i / best_combo["sum"])
                
                if name not in df_result.columns:
                    df_result[name] = 0.0
                
                df_result.at[t, name] = assigned_value
                assigned_this_step += assigned_value
            
            prev_combo = best_combo["names"]
        else:
            prev_combo = None

        # Captura de residuos o flujos no identificados
        residual = flow_t - assigned_this_step
        if residual > 0.01: # Umbral para ignorar ruido decimal
            if "No Detectado" not in df_result.columns:
                df_result["No Detectado"] = 0.0
            df_result.at[t, "No Detectado"] += residual

    # Auditoría de litros
    total_original_liters = current_flow.sum() / 60
    total_assigned_liters = df_result.sum().sum() / 60
    diff = total_original_liters - total_assigned_liters

    print(f"[AUDIT] Total original litros: {total_original_liters:.4f}")
    print(f"[AUDIT] Total asignado litros: {total_assigned_liters:.4f}")
    print(f"[AUDIT] Diferencia final: {diff:.6f}")

    # Construcción de la lista de eventos para la base de datos
    events_list = []
    for col in df_result.columns:
        is_active = df_result[col] > 0
        changes = is_active.astype(int).diff()

        starts = df_result.index[changes == 1]
        ends = df_result.index[changes == -1]

        if is_active.iloc[0]:
            starts = starts.insert(0, df_result.index[0])
        if len(ends) < len(starts):
            ends = ends.append(pd.Index([df_result.index[-1]]))

        for s, e in zip(starts, ends):
            duration = (e - s).total_seconds()
            if duration < 2: # Ignorar eventos ultra-cortos
                continue

            segment = df_result.loc[s:e, col]
            volume_liters = segment.sum() / 60
            avg_flow = segment.mean()

            events_list.append({
                "device": col,
                "start_time": s,
                "end_time": e,
                "duration_seconds": duration,
                "flow_rate": float(avg_flow),
                "volume_liters": float(volume_liters)
            })

    df_events = pd.DataFrame(events_list)
    return df_events, df_result

def train_disaggregator(df: pd.DataFrame, max_clusters: int = 6, min_stable_flow: float = 0.5, stable_delta: float = 0.2):

    df_proc = preprocess_signal(df)

    # Detectar zonas estables
    stable_mask = (
        (df_proc['delta'].abs() < stable_delta) &
        (df_proc['flow_smooth'] > min_stable_flow)
    )

    stable_values = df_proc.loc[stable_mask, 'flow_smooth'].values.reshape(-1, 1)

    if len(stable_values) < 100:
        print("No hay suficientes datos estables para entrenar.")
        return {}

    # Escalar datos (importante para clustering robusto)
    scaler = StandardScaler()
    stable_scaled = scaler.fit_transform(stable_values)

    # KMeans clustering
    n_clusters = min(max_clusters, len(stable_values) // 100 + 2)

    kmeans = KMeans(
        n_clusters=n_clusters,
        n_init=20,
        random_state=42
    )

    kmeans.fit(stable_scaled)

    labels = kmeans.labels_

    profiles = {}
    category_counters = {}

    # Construir perfiles con media y desviación
    for i in range(n_clusters):

        cluster_values = stable_values[labels == i].flatten()

        if len(cluster_values) < 30:
            continue

        mean = np.mean(cluster_values)
        std = np.std(cluster_values)

        base_category = get_device_category(mean)
        category_counters[base_category] = category_counters.get(base_category, 0) + 1
        device_name = f"{base_category}_{category_counters[base_category]}"
        profiles[i] = {
            "name": device_name,
            "mean_flow": float(round(mean, 2)),
            "st_deviation": float(round(std, 2)),
            "weight": float(round(len(cluster_values) / len(stable_values), 3))
        }

    print("Perfiles entrenados:")
    for p in profiles.values():
        print(f"Dispositivo: {p['name']} | Media: {p['mean_flow']} L/min | Std: {p['st_deviation']} | Peso: {p['weight']}")

    return profiles
